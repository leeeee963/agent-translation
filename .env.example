# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────
SUDO_API_KEY=your_api_key_here

# ── Access control ───────────────────────────────────────────────────
# Required for all /api/* requests (login page on the frontend).
# Set to a strong, random string before deploying to a public URL.
ACCESS_PASSWORD=

# Session signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left empty, a random secret is generated at startup (sessions are lost on restart).
SESSION_SECRET=

# ── Database ─────────────────────────────────────────────────────────
# Empty → SQLite at data/app.db (good for local dev).
# Production (Postgres) example: postgresql+psycopg2://user:pass@host:5432/dbname
# (Heroku-style "postgres://..." also accepted; auto-converted.)
DATABASE_URL=

# ── File storage ─────────────────────────────────────────────────────
# "local" (default) writes to STORAGE_LOCAL_ROOT (or data/storage if empty).
# "s3" uses any S3-compatible service (AWS S3, Cloudflare R2, Backblaze B2, etc).
STORAGE_BACKEND=local
STORAGE_LOCAL_ROOT=

# Required if STORAGE_BACKEND=s3
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
