# Copy this file to .env and fill in your values
SUDO_API_KEY=your_api_key_here

# Access password — required for all /api/* requests (login page on the frontend)
# Set to a strong, random string before deploying to a public URL.
ACCESS_PASSWORD=

# Session signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If left empty, a random secret is generated at startup (sessions are lost on restart).
SESSION_SECRET=
